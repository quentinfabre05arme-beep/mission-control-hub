{
  "version": 2,
  "public": true,
  "github": {
    "enabled": false
  },
  "builds": [
    {
      "src": "mission_control/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/mission_control/(.*)",
      "dest": "/mission_control/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/mission_control/index.html"
    }
  ]
}